NEXTAUTH_SECRET=replace-with-a-local-secret
NEXTAUTH_URL=http://127.0.0.1:3000
# Local prototype role switching. For public deploys, only set this to true when demo access is intentional.
TAMS_DEMO_AUTH_ENABLED=true
# Railway setup uses this public URL instead of copying the local callback URL.
# TAMS_RAILWAY_APP_URL=https://your-railway-domain
# Optional override for `corepack pnpm services:check`.
# TAMS_HUB_HEALTH_URL=http://127.0.0.1:3000
CODEX_LB_API_KEY=
CODEX_LB_BASE_URL=https://codex-lb-production-6b47.up.railway.app/v1
CODEX_LB_MODEL=gpt-5.4
CODEX_LB_REASONING_EFFORT=high
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
