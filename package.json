{
  "name": "tams-hub-prototype",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "corepack pnpm access:check && corepack pnpm access:convex-check && corepack pnpm ux:a11y:check && corepack pnpm demo:check && corepack pnpm stabilization:test",
    "stabilization:test": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-loader ./scripts/ts-extension-loader.mjs --test tests/*.test.mjs",
    "ux:a11y:check": "node scripts/check-ux-a11y.mjs",
    "demo:check": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-loader ./scripts/ts-extension-loader.mjs scripts/check-demo-path.mjs",
    "access:check": "node scripts/check-access-auth.mjs",
    "access:convex-check": "node --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types --experimental-loader ./scripts/ts-extension-loader.mjs scripts/check-access-enforcement.mjs",
    "services:check": "node scripts/check-services.mjs",
    "setup:convex": "node scripts/setup-convex.mjs",
    "setup:railway": "node scripts/setup-railway.mjs",
    "convex:codegen": "convex codegen --typecheck enable",
    "convex:dev-once": "convex dev --once"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "convex": "^1.19.4",
    "gsap": "^3.15.0",
    "lucide-react": "^0.468.0",
    "next": "^15.0.4",
    "next-auth": "^4.24.11",
    "openai": "^4.77.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.4",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a"
}
